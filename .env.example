# Copiar a infra/.env y rellenar con valores reales antes de "docker compose up".
# Sin estos valores el arranque falla explícitamente (a propósito: nada de
# defaults tipo "changeme" en producción — ver server/src/config/env.ts).

POSTGRES_PASSWORD=
# Genera uno con: openssl rand -base64 48
JWT_SECRET=
CORS_ORIGIN=https://uclcampus.com,https://crm.uclcampus.com,https://intranet.uclcampus.com
# Opcional: solo si quieres que la sesión se comparta entre subdominios
# (login en uclcampus.com válido también en crm.uclcampus.com). Dejar vacío
# para cookie de un solo host (más restrictivo).
COOKIE_DOMAIN=.uclcampus.com
