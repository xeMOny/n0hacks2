PORT=4000
DATABASE_URL=postgres://malta:changeme@localhost:5432/malta
JWT_SECRET=changeme
NODE_ENV=development

# Chatbot público de la landing (opcional: si falta, /api/chat responde 503
# en vez de tumbar el resto de la API). Clave de https://console.anthropic.com
ANTHROPIC_API_KEY=
# Alias del modelo, no el ID con fecha. Haiku 4.5 por coste (tráfico público
# anónimo); subir a claude-opus-4-8 si hace falta más calidad de respuesta.
CHAT_MODEL=claude-fable-5
